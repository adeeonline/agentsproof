{
  "name": "agentsproof",
  "version": "1.0.1",
  "description": "Eval and shareable replay reports for AI agents — drop in one decorator, get a public report URL.",
  "license": "MIT",
  "author": "Assad Ullah <assad@agentsproof.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adeeonline/agentsproof.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agent",
    "eval",
    "llm",
    "tracing",
    "observability"
  ],
  "dependencies": {
    "nanoid": "^5.1.11"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
